{
  "rewrites": [
    { "source": "/", "destination": "/designs/landing.html" },
    { "source": "/chat", "destination": "/designs/chat.html" },
    { "source": "/onboarding", "destination": "/designs/onboarding_1_role.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
